<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #F4F6F9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.proyecto.GestionUsuariosController">

    <!-- ================= TOP ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: linear-gradient(to right, #2C5FA8, #1F3F6D); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10,0,0,3);">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Sistema de Gestión de Progreso y Retención"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Cerrar Sesión"
                    style="-fx-background-color: white; -fx-text-fill: #1F3F6D; -fx-font-weight: bold; -fx-background-radius: 20;"/>
        </HBox>
    </top>

    <!-- ================= MENU LATERAL ================= -->
    <left>
        <VBox spacing="12" prefWidth="230"
              style="-fx-background-color: #1F3F6D;">
            <padding>
                <Insets top="25" left="15" right="15"/>
            </padding>

            <Button text="Gestión de Usuarios" maxWidth="Infinity"
                    style="-fx-background-radius: 10; -fx-font-weight: bold;"/>
            <Button text="Causas de Abandono" maxWidth="Infinity"
                    style="-fx-background-radius: 10;"/>
            <Button text="Reportes" maxWidth="Infinity"
                    style="-fx-background-radius: 10;"/>
            <Button text="Estadísticas" maxWidth="Infinity"
                    onAction="#irEstadisticas"
                    style="-fx-background-radius: 10;"/>
            <Button text="Salir" maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 10;"/>
        </VBox>
    </left>

    <!-- ================= CENTRO ================= -->
    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <Label text="Lista de Usuarios"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

            <!-- ===== TABLA ===== -->
            <TableView fx:id="usuariosTable" prefHeight="300"
                       style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8,0,0,2);">
                <columns>
                    <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="120"/>
                    <TableColumn fx:id="edadColumn" text="Edad" prefWidth="60"/>
                    <TableColumn fx:id="pesoColumn" text="Peso" prefWidth="70"/>
                    <TableColumn fx:id="alturaColumn" text="Altura" prefWidth="70"/>
                    <TableColumn fx:id="objetivoColumn" text="Objetivo" prefWidth="120"/>
                    <TableColumn fx:id="caloriasColumn" text="Calorías" prefWidth="90"/>
                </columns>
            </TableView>

            <!-- ===== BOTONES CRUD ===== -->
            <HBox spacing="15">
                <Button text="Agregar Usuario"
                        style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-background-radius: 20;"/>
                <Button text="Editar Usuario"
                        style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-background-radius: 20;"/>
                <Button text="Eliminar Usuario"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 20;"/>
            </HBox>

            <Separator/>

            <Label text="Detalle del Usuario"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

            <!-- ===== FORMULARIO ===== -->
            <GridPane hgap="20" vgap="18">

                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nombreField"
                           style="-fx-background-radius: 10;"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Sexo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="sexoComboBox"
                          style="-fx-background-radius: 10;"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Edad:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="edadField"
                           style="-fx-background-radius: 10;"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Peso:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="pesoField"
                           style="-fx-background-radius: 10;"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Altura:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="alturaField"
                           style="-fx-background-radius: 10;"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Índice de Grasa:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="grasaField"
                           style="-fx-background-radius: 10;"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>

                <Label text="Tiempo Entrenando:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <ComboBox fx:id="actividadBox"
                          style="-fx-background-radius: 10;"
                          GridPane.rowIndex="6"
                          GridPane.columnIndex="1"/>

                <Label text="Objetivo:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <ComboBox fx:id="objetivoComboBox"
                          style="-fx-background-radius: 10;"
                          GridPane.rowIndex="7"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <!-- ===== BOTONES INFERIORES ===== -->
            <HBox spacing="15">
                <Button text="Calcular Requerimientos"
                        onAction="#calcularRequerimientos"
                        style="-fx-background-color: #9B59B6; -fx-text-fill: white; -fx-background-radius: 20;"/>
                <Button text="Guardar"
                        style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-background-radius: 20;"/>
                <Button text="Actualizar"
                        style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-background-radius: 20;"/>
                <Button text="Eliminar"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 20;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
